# Heroku Managed Inference and Agents (Claude 4.5 Sonnet). The MCP tool loop
# runs in lib/llm/heroku.ts against this OpenAI-compatible endpoint.
# Auto-populated by the heroku-inference addon when deployed.
INFERENCE_URL=https://us.inference.heroku.com
INFERENCE_KEY=
INFERENCE_MODEL_ID=claude-4-5-sonnet

# Optional second Heroku Inference stack (e.g. Kimi on Onyx) — same OpenAI-
# compatible API as INFERENCE_*. Used only if the primary Claude call fails;
# all routes use Claude first.
# HEROKU_INFERENCE_ONYX_URL=https://us.inference.heroku.com
# HEROKU_INFERENCE_ONYX_KEY=
# HEROKU_INFERENCE_ONYX_MODEL_ID=kimi-k2-thinking

# Salesforce External Client App (ECA). Must have:
#   - OAuth 2.1 Authorization Code + PKCE enabled (default for ECAs)
#   - `mcp_api` scope ("Access Salesforce hosted MCP servers")
#   - `cdp_api` scope ("Access all Data Cloud API resources") — required for
#     the Data Cloud MCP to be visible; without it list_tools returns 0 tools
#   - `refresh_token, offline_access` scope
#   - http://localhost:3000/callback in its Callback URL list
#   Runtime authorize request is: scope=mcp_api cdp_api refresh_token
#   (see lib/salesforce/oauth.ts). Keep scope list short — ECAs reject longer
#   scope strings with OAUTH_CODE_CRED_SCOPE_TOO_LONG.
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_LOGIN_URL=https://login.salesforce.com
SF_REDIRECT_URI=http://localhost:3000/callback

# Optional overrides for scripts that need a pre-fetched SF access token
# (verify:mcp, CI smoke tests). Capture one with `npm run sf:login`.
# SF_ACCESS_TOKEN=
# SF_INSTANCE_URL=

# Heroku (set automatically on deploy)
DATABASE_URL=
REDIS_URL=

# ElevenLabs (optional). When set, Morning Brief / Pulse "Listen" uses POST
# /api/tts (MP3). REDIS_URL caches audio by hash of the script text. If unset,
# the client falls back to the Web Speech API only.
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
#
# TTS auth: default requires Salesforce session cookie. Set to 0 only for a
# controlled demo if /api/tts returns 401 while the rest of the app works
# (in-memory rate limit still applies). Re-enable after filming.
# TTS_REQUIRE_SF_AUTH=1

# App
APP_URL=http://localhost:3000
NODE_ENV=development

# Banker persona (for demo)
DEMO_BANKER_USER_ID=
DEMO_BANKER_NAME=
# IANA timezone for server-side prompts (e.g. Morning Brief context). Default in code is America/New_York if unset.
# DEMO_BANKER_TZ=America/New_York
