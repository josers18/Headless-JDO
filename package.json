{
  "name": "horizon",
  "version": "0.1.0",
  "private": true,
  "description": "Horizon — the headless home page for the relationship banker.",
  "repository": {
    "type": "git",
    "url": "https://github.com/josers18/Headless-JDO.git"
  },
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "verify:mcp": "tsx --env-file=.env scripts/verify-mcp.ts",
    "seed:dc": "tsx --env-file=.env scripts/seed-data-cloud.ts",
    "sf:login": "tsx --env-file=.env scripts/sf-login.ts",
    "smoke:api": "tsx --env-file=.env scripts/smoke-api.ts",
    "verify:p01": "tsx --env-file=.env scripts/verify-p01.ts",
    "verify:p02": "tsx --env-file=.env scripts/verify-p02.ts",
    "mcp:check": "tsx --env-file=.env scripts/mcp-check.ts",
    "mcp:refresh": "bash scripts/mcp-refresh.sh",
    "refresh:dc-metadata": "tsx --env-file=.env scripts/refresh-dc-metadata.ts",
    "test:signoff": "tsx scripts/test-signoff-policy.ts"
  },
  "cacheDirectories": [
    "node_modules",
    ".next/cache"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "clsx": "^2.1.1",
    "ioredis": "^5.4.1",
    "lucide-react": "^0.454.0",
    "next": "^15.5.15",
    "openai": "^6.34.0",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.8.7",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
